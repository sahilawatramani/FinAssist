# FinAssist production template
# Copy to backend/.env in production-like environment and fill all values.

ENV=production
DATABASE_URL=

# Security and auth
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
WEBHOOK_SECRET=
SMS_FORWARD_SECRET=
SMS_FORWARD_DEFAULT_USER_EMAIL=

# Runtime and ops
AUTO_CREATE_TABLES=false
LOG_LEVEL=INFO
RATE_LIMIT_BACKEND=redis
REDIS_URL=
REPORT_LOOKBACK_DAYS=30

# App hardening
CORS_ALLOWED_ORIGINS=https://your-frontend.example.com
CORS_ALLOW_CREDENTIALS=true
TRUSTED_HOSTS=api.your-domain.com
SECURITY_HEADERS_ENABLED=true
REQUIRE_HTTPS=true

# Agentic controls
AUTO_CLASSIFICATION_ENABLED=true
LANGGRAPH_CHECKPOINT_PATH=./data/langgraph_checkpoints.sqlite

# LLM provider
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-1.5-flash

# Alternative: Ollama (local LLM, no API key required)
# Set LLM_PROVIDER=ollama and uncomment these to use Ollama instead
# OLLAMA_API_BASE_URL=http://localhost:11434
# OLLAMA_CHAT_MODEL=mistral
