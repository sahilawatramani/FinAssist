# ==========================
# FinAssist Backend .env
# ==========================

# -------- Core App --------
ENV=development
DATABASE_URL=sqlite:///./data/finassist.db
WEBHOOK_SECRET=finassist-dev-secret
SMS_FORWARD_SECRET=
SMS_FORWARD_DEFAULT_USER_EMAIL=
REPORT_LOOKBACK_DAYS=30
AUTO_CREATE_TABLES=true
LOG_LEVEL=INFO
RATE_LIMIT_BACKEND=memory
REDIS_URL=
CORS_ALLOWED_ORIGINS=*
CORS_ALLOW_CREDENTIALS=true
TRUSTED_HOSTS=*
SECURITY_HEADERS_ENABLED=true
REQUIRE_HTTPS=false
AUTO_CLASSIFICATION_ENABLED=true
LANGGRAPH_CHECKPOINT_PATH=./data/langgraph_checkpoints.sqlite
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# -------- OpenAI --------
# Required for chat + LLM fallback classification.
# App still runs with rule-based classification if empty.
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-3.5-turbo

# -------- Gemini --------
# Recommended deployable alternative to OpenAI.
LLM_PROVIDER=openai
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-1.5-flash

# -------- SMS Provider APIs (Optional: choose one) --------
# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# MSG91
MSG91_AUTH_KEY=

# Fast2SMS
FAST2SMS_API_KEY=

# -------- Payment Gateway APIs (Optional future integrations) --------
# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Stripe
STRIPE_SECRET_KEY=

# -------- Account Aggregator / FIU (Optional future integrations) --------
AA_CLIENT_ID=
AA_CLIENT_SECRET=
AA_REDIRECT_URI=
AA_WEBHOOK_SECRET=
